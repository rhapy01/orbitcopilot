# --- Off-chain data plane (required) ---

# Postgres — Neon / Vercel Postgres / local
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Redis — Upstash (Vercel KV integration). Use the rediss:// URL, not REST-only.
# Either name works; REDIS_URL is preferred, KV_URL is the Vercel alias.
REDIS_URL=rediss://default:TOKEN@xxxx.upstash.io:6379
KV_URL=rediss://default:TOKEN@xxxx.upstash.io:6379
# Optional REST credentials (not used by Orbit's ioredis client)
# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# --- Protocol / LLM ---
SOROSWAP_API_KEY=sk_your_key_here
OPENROUTER_API_KEY=
# LLM_MODEL=openai/gpt-4o-mini

# --- On-chain Orbit markets (Soroban) ---
ORBIT_PREDICT_CONTRACT_ID=C...
ORBIT_PERPS_CONTRACT_ID=C...

# PORT=3001
