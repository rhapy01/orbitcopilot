# --- Off-chain data plane (required) ---

# Postgres - Neon / Vercel Postgres / local
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Redis - Upstash (Vercel KV integration). Use the rediss:// URL, not REST-only.
REDIS_URL=rediss://default:TOKEN@xxxx.upstash.io:6379
KV_URL=rediss://default:TOKEN@xxxx.upstash.io:6379

# --- Protocol / LLM ---
SOROSWAP_API_KEY=sk_your_key_here
OPENROUTER_API_KEY=
# LLM_MODEL=openai/gpt-4o-mini

# Optional - admin S… key for scripts/resolve-predict.mjs (testnet only, never commit)
# ORBIT_ADMIN_SECRET_KEY=

# --- On-chain (Stellar Testnet - deployed) ---
ORBIT_PREDICT_CONTRACT_ID=CBSTVO2UCF2XVMHXFAKS5I2XMURT222MY5OWOXITW45B2AB6R7FHMTDC
ORBIT_PERPS_CONTRACT_ID=CC2IDBXQLA5L6NDWMGV3M6JH5NVK6NG26HMQCEYEHLJUJ7Q35KXADT3G
ORBIT_NFT_CONTRACT_ID=CA34E5V5SAV64PPMS7IKARAVUV3B423PLPCMNPJ6WALXP4Q3KS2C64HU
# SEP-50 collection factory (anyone can create collections via chat)
ORBIT_NFT_FACTORY_CONTRACT_ID=CB6PGYXVPCTJY5PILVFGFMI5WI5GCUI36GG6T7443YVJNV6EZ73FQJ55
# Public URL used for SEP-50 metadata token_uri hosting
# ORBIT_PUBLIC_URL=https://orbitpilot.vercel.app
ORBIT_SUPPLY_CONTRACT_ID=CAK6JTURV46VP2HSVFZORYJHBC4CYP4BDVJLQJK4AXSN6X75SIZRB6QV
# testnet | public - Friendbot only runs on testnet
STELLAR_NETWORK=testnet

# Production WebAuthn - on Vercel set BOTH to the live domain (not localhost):
# WEBAUTHN_RP_ID=orbitpilot.vercel.app
# WEBAUTHN_ORIGIN=https://orbitpilot.vercel.app

# --- Internal wallet / auth (REQUIRED on Vercel) ---
# Generate: openssl rand -hex 32
# Without KMS_SECRET, passkey signup returns 500 after Chrome creates the passkey.
KMS_SECRET=

# Local-only WebAuthn defaults (override on Vercel with production domain above)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Google SMTP (App Password - not your normal Gmail password)
# 1. Enable 2FA on Google Account
# 2. Create App Password for Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=Orbit <you@gmail.com>

# PORT=3001
